<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>
<?import javafx.geometry.Insets?>

<StackPane xmlns:fx="http://javafx.com/fxml/1" fx:controller="vista.PantallaMenu" prefHeight="600.0" prefWidth="800.0" styleClass="root">
    
    <!-- 1. SPLASH SCREEN -->
    <VBox fx:id="splashContainer" alignment="CENTER" spacing="30" styleClass="splash-container" maxWidth="Infinity" maxHeight="Infinity">
        <!-- The title is now part of the background image -->
        <Region prefHeight="400" /> 
        <VBox alignment="CENTER" spacing="15">
            <Button text="EMPEZAR" onAction="#handleStartSplash" styleClass="button-large" prefWidth="250" />
            <Button text="SALIR" onAction="#handleQuitGame" styleClass="button-secondary" prefWidth="250" />
        </VBox>
    </VBox>

    <!-- 2. LOGIN SCREEN -->
    <VBox fx:id="loginContainer" alignment="CENTER" spacing="20" visible="false" maxWidth="400">
        <Text text="INICIAR SESIÓN" styleClass="title-text" />
        <TextField fx:id="userField" promptText="Nombre de usuario" maxWidth="250" />
        <PasswordField fx:id="passField" promptText="Contraseña" maxWidth="250" />
        <HBox spacing="10" alignment="CENTER">
            <Button text="Entrar" onAction="#handleLogin" />
            <Button text="Registrarse" onAction="#showCreatePlayer" />
        </HBox>
        <Label fx:id="loginErrorLabel" text="" visible="false" styleClass="error-text" />
        <Button text="Salir" onAction="#handleQuitGame" styleClass="button-secondary" />
    </VBox>

    <!-- 3. CREATE PLAYER SCREEN -->
    <VBox fx:id="createPlayerContainer" alignment="CENTER" spacing="20" visible="false" maxWidth="400">
        <Text text="NUEVO JUGADOR" styleClass="title-text" />
        <TextField fx:id="newUserNameField" promptText="Nombre de usuario" maxWidth="250" />
        <PasswordField fx:id="newUserPassField" promptText="Contraseña" maxWidth="250" />
        <HBox spacing="10" alignment="CENTER">
            <Button text="Crear" onAction="#handleCreatePlayer" />
            <Button text="Volver" onAction="#showLogin" />
        </HBox>
    </VBox>

    <!-- 4. MAIN MENU -->
    <VBox fx:id="mainMenuContainer" alignment="CENTER" spacing="20" visible="false">
        <Text fx:id="welcomeText" text="Bienvenido, Usuario" styleClass="welcome-text" />
        <Text text="MENU PRINCIPAL" styleClass="title-text" />
        <VBox spacing="15" alignment="CENTER" maxWidth="300">
            <Button text="NUEVA PARTIDA" onAction="#showPlayerConfig" prefWidth="200" />
            <Button text="CARGAR PARTIDA" onAction="#showLoadGame" prefWidth="200" />
            <Button text="CERRAR SESIÓN" onAction="#showLogin" prefWidth="200" />
            <Button text="SALIR" onAction="#handleQuitGame" prefWidth="200" styleClass="button-secondary" />
        </VBox>
    </VBox>

    <!-- 5. PLAYER CONFIGURATION (REDESIGNED) -->
    <VBox fx:id="playerConfigContainer" alignment="CENTER" spacing="40" visible="false" maxWidth="950">
        <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>
        
        <Text text="CONFIGURACIÓN DE PERSONAJES" styleClass="title-text" />
        
        <HBox fx:id="playerSlotsContainer" spacing="25" alignment="CENTER" minHeight="250">
            <!-- Cards (P1, P2, P3, P4) and "+" buttons will be injected here -->
        </HBox>

        <VBox spacing="25" alignment="CENTER">
            <CheckBox fx:id="focaCheckbox" text="AÑADIR FOCA LOCA (CPU)" style="-fx-font-weight: bold; -fx-text-fill: #0d47a1;"/>
            
            <Label fx:id="playerConfigErrorLabel" text="" styleClass="error-text" />
            
            <HBox spacing="20" alignment="CENTER">
                <Button text="EMPEZAR PARTIDA" onAction="#showSeedSelection" styleClass="button-large" prefWidth="300" />
                <Button text="VOLVER AL MENÚ" onAction="#showMainMenu" styleClass="button-secondary" prefWidth="200" />
            </HBox>
        </VBox>
    </VBox>

    <!-- 6. LOAD GAME SCREEN -->
    <VBox fx:id="loadGameContainer" alignment="CENTER" spacing="20" visible="false" maxWidth="500">
        <Text text="MIS PARTIDAS" styleClass="title-text" />
        <ListView fx:id="savedGamesListView" prefHeight="300" maxWidth="400" />
        <HBox spacing="10" alignment="CENTER">
            <Button text="CARGAR" onAction="#handleConfirmLoadGame" />
            <Button text="VOLVER" onAction="#showMainMenu" />
        </HBox>
    </VBox>

    <!-- 7. SEED SELECTION -->
    <VBox fx:id="seedSelectionContainer" alignment="CENTER" spacing="20" visible="false">
        <Text text="SELECCIÓN DE SEED" styleClass="title-text" />
        <Text text="Introduce 48 números indicando el tipo de casilla" styleClass="help-text" />
        <TextField fx:id="seedField" promptText="Solo números (48 chars)" maxWidth="350" alignment="CENTER" />
        <Label fx:id="seedErrorLabel" text="" styleClass="error-text" />
        <HBox spacing="10" alignment="CENTER">
            <Button text="ALEATORIA" onAction="#handleRandomSeed" />
            <Button text="MANUAL" onAction="#handleManualSeed" />
            <Button text="ATRÁS" onAction="#showPlayerConfig" />
        </HBox>
    </VBox>

    <!-- Custom small fullscreen hint -->
    <Label fx:id="fullScreenHint" text="Pulse Esc para salir de pantalla completa" 
           styleClass="fullscreen-hint" StackPane.alignment="TOP_CENTER" visible="false" />

</StackPane>
