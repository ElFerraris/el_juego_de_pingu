<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import java.net.URL?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
           fx:controller="controlador.SeedSelectionController" 
           styleClass="root-plain-bg" prefHeight="720.0" prefWidth="1280.0">
    <stylesheets>
        <URL value="@style.css" />
    </stylesheets>
    
    <Region style="-fx-background-color: rgba(5,20,60,0.15);"/>

    <VBox spacing="40" alignment="CENTER" maxWidth="1000" maxHeight="650" styleClass="glass-panel">
        <Label text="CONFIGURACIÓN DEL MUNDO" styleClass="title-text" />
        
        <VBox spacing="25" alignment="CENTER">
            <Label text="OPCIÓN A: ELEGIR UN MUNDO RECOMENDADO" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-opacity: 0.8;"/>
            <HBox spacing="20" alignment="CENTER">
                <Button fx:id="btnIsla" text="ISLA PINGÜINO" onAction="#handleQuickSeed" styleClass="button" prefWidth="250" prefHeight="90" />
                <Button fx:id="btnValle" text="VALLE HELADO" onAction="#handleQuickSeed" styleClass="button" prefWidth="250" prefHeight="90" />
                <Button fx:id="btnMontana" text="MONTAÑA CRISTAL" onAction="#handleQuickSeed" styleClass="button" prefWidth="250" prefHeight="90" />
            </HBox>
        </VBox>

        <Separator maxWidth="700" />

        <VBox spacing="20" alignment="CENTER">
            <Label text="OPCIÓN B: SEMILLA PERSONALIZADA" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-opacity: 0.8;"/>
            <HBox spacing="20" alignment="CENTER">
                <Button fx:id="btnCustom" text="ESCRIBIR MI PROPIA SEMILLA" onAction="#handleEnableCustomSeed" styleClass="button" prefWidth="350" prefHeight="60" />
                <TextField fx:id="seedField" promptText="Solo números (ej: 2233...)" disable="true" maxWidth="400" 
                           style="-fx-font-size: 22px; -fx-alignment: center; -fx-prompt-text-fill: derive(-fx-control-inner-background, -30%);"/>
            </HBox>
            <Label fx:id="errorLabel" styleClass="error-text" text="" style="-fx-text-fill: #ff5252; -fx-font-size: 18px;" />
        </VBox>

        <HBox spacing="40" alignment="CENTER" style="-fx-padding: 20 0 0 0;">
            <Button text="VOLVER" onAction="#handleBack" styleClass="button-secondary" prefWidth="220" prefHeight="70" />
            <Button text="INICIAR PARTIDA" onAction="#handleStartGame" styleClass="button-primary" prefWidth="320" prefHeight="80" />
        </HBox>
    </VBox>
</StackPane>
