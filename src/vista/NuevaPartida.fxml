<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>


<AnchorPane prefHeight="900.0" prefWidth="1800.0" stylesheets="@global_style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="vista.NuevaPartida">
   <children>
      <!-- Fondo Degradado Glacial -->
      <AnchorPane prefHeight="900.0" prefWidth="1800.0" style="-fx-background-color: linear-gradient(to bottom, #1A2B3C, #4682B4);" />
      
      <Label layoutX="620.0" layoutY="120.0" prefHeight="133.0" prefWidth="560.0" styleClass="title-label" text="CREAR PARTIDA" textAlignment="CENTER" />
      
      <Button fx:id="btn_volver" layoutX="50.0" layoutY="790.0" mnemonicParsing="false" onAction="#handleVolver" prefHeight="65.0" prefWidth="200.0" styleClass="pixel-button" text="VOLVER" />
      
      <Button fx:id="bnt_aleatorio" layoutX="741.0" layoutY="320.0" mnemonicParsing="false" onAction="#handleSiguiente" prefHeight="80.0" prefWidth="320.0" styleClass="pixel-button" text="TABLERO ALEATORIO" />
      
      <Label layoutX="741.0" layoutY="460.0" styleClass="pixel-label" text="INTRODUCIR SEMILLA (SEED):" />
      <TextField fx:id="txt_seed" layoutX="741.0" layoutY="490.0" prefHeight="50.0" prefWidth="320.0" style="-fx-background-radius: 0; -fx-border-color: black; -fx-border-width: 3px;" />
      
      <Button fx:id="bnt_seed" layoutX="741.0" layoutY="560.0" mnemonicParsing="false" onAction="#handleSiguiente" prefHeight="80.0" prefWidth="320.0" styleClass="pixel-button" text="USAR SEED" />
   </children>
</AnchorPane>
