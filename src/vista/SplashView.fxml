<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns:fx="http://javafx.com/fxml/1" fx:controller="controlador.SplashController" styleClass="root, root-main-bg" prefHeight="720.0" prefWidth="1280.0">
    <VBox fx:id="splashContainer" alignment="CENTER" spacing="40" styleClass="splash-container" maxWidth="Infinity" maxHeight="Infinity">
        <Region prefHeight="450" /> 
        <VBox alignment="CENTER" spacing="20">
            <Button text="EMPEZAR" onAction="#handleStartSplash" prefWidth="320" prefHeight="60" styleClass="button-large" />
            <Button text="SALIR" onAction="#handleQuitGame" prefWidth="200" styleClass="button-secondary" />
        </VBox>
    </VBox>
    <Label fx:id="fullScreenHint" text="Pulse Esc para salir de pantalla completa" 
           styleClass="fullscreen-hint" StackPane.alignment="TOP_CENTER" visible="false" />
</StackPane>
