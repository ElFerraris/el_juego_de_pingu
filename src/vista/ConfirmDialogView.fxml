<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
           fx:controller="controlador.ConfirmDialogController" 
           styleClass="root-plain-bg" prefHeight="720.0" prefWidth="1280.0">
    <stylesheets>
        <URL value="@style.css" />
    </stylesheets>
    
    <!-- Oscurecer un poco el fondo para dar foco al diálogo -->
    <Region style="-fx-background-color: rgba(0,0,0,0.3);" />
    
    <VBox spacing="40" alignment="CENTER" maxWidth="600" maxHeight="400" styleClass="glass-panel">
        <Label fx:id="titleLabel" text="CONFIRMACIÓN" styleClass="title-text" />
        
        <Label fx:id="messageLabel" text="¿Estás seguro de que quieres realizar esta acción?" 
               style="-fx-font-size: 24px; -fx-text-fill: white; -fx-text-alignment: center;" wrapText="true" />
        
        <HBox spacing="30" alignment="CENTER">
            <Button text="SÍ, ESTOY SEGURO" onAction="#handleYes" prefWidth="250" prefHeight="60" styleClass="button-danger" />
            <Button text="NO, VOLVER" onAction="#handleNo" prefWidth="250" prefHeight="60" styleClass="button-secondary" />
        </HBox>
    </VBox>
</StackPane>
