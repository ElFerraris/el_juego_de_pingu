<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="700.0" prefWidth="1000.0"
    stylesheets="@global_style.css"
    xmlns="http://javafx.com/javafx/25"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="vista.CargarPartida">

    <AnchorPane prefHeight="700.0" prefWidth="1000.0"
        style="-fx-background-color: linear-gradient(to bottom, #1A2B3C, #4682B4);" />

    <Label layoutX="100.0" layoutY="40.0" prefWidth="800.0" prefHeight="60.0"
        styleClass="title-label" text="CARGAR PARTIDA" textAlignment="CENTER" />

    <!-- Tabla de partidas -->
    <TableView fx:id="tabla_partidas" layoutX="80.0" layoutY="130.0"
        prefWidth="840.0" prefHeight="400.0"
        style="-fx-background-color: rgba(26,43,60,0.85);">
        <columns>
            <TableColumn fx:id="col_id"    text="ID"       prefWidth="80" />
            <TableColumn fx:id="col_seed"  text="Seed"     prefWidth="340" />
            <TableColumn fx:id="col_turno" text="Turno"    prefWidth="120" />
            <TableColumn fx:id="col_fecha" text="Fecha"    prefWidth="300" />
        </columns>
    </TableView>

    <Label fx:id="lbl_error" layoutX="80.0" layoutY="545.0"
        prefWidth="840.0" text=" "
        style="-fx-text-fill: #FF6E6E; -fx-font-size: 13px;" />

    <!-- Botones -->
    <HBox layoutX="280.0" layoutY="580.0" spacing="30.0" alignment="CENTER">
        <Button text="VOLVER" onAction="#handleVolver"
            prefWidth="180.0" prefHeight="55.0" styleClass="pixel-button" />
        <Button text="CARGAR" onAction="#handleCargar"
            prefWidth="220.0" prefHeight="55.0"
            styleClass="pixel-button"
            style="-fx-background-color: #2ECC71; -fx-text-fill: white;" />
    </HBox>

</AnchorPane>
