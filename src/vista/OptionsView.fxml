<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
           fx:controller="controlador.OptionsController" 
           styleClass="root-plain-bg" prefHeight="720.0" prefWidth="1280.0">
    <stylesheets>
        <URL value="@style.css" />
    </stylesheets>
    
    <Region style="-fx-background-color: rgba(5,20,60,0.15);"/>

    <VBox spacing="20" alignment="CENTER" maxWidth="1000" maxHeight="680" styleClass="glass-panel" style="-fx-padding: 40;">
        <Label text="OPCIONES" styleClass="title-text" />
        
        <TabPane fx:id="optionsTabPane" tabClosingPolicy="UNAVAILABLE" prefHeight="400" maxWidth="850">
            <tabs>
                <!-- PESTAÑA VÍDEO -->
                <Tab text="VÍDEO">
                    <VBox spacing="25" alignment="TOP_CENTER" style="-fx-padding: 50 40 0 40;">
                        <!-- Fila Resolución -->
                        <HBox alignment="CENTER_LEFT" spacing="20">
                            <Label text="RESOLUCIÓN" style="-fx-font-size: 24px; -fx-text-fill: #0d47a1; -fx-font-weight: bold;" />
                            <Region HBox.hgrow="ALWAYS" />
                            <ComboBox fx:id="resolutionCombo" prefWidth="350" />
                        </HBox>
                        
                        <!-- Fila Fullscreen -->
                        <HBox alignment="CENTER_LEFT" spacing="20">
                            <Label text="PANTALLA COMPLETA" style="-fx-font-size: 24px; -fx-text-fill: #0d47a1; -fx-font-weight: bold;" />
                            <Region HBox.hgrow="ALWAYS" />
                            <CheckBox fx:id="fullscreenCheck" text="" styleClass="premium-checkbox" />
                        </HBox>
                    </VBox>
                </Tab>
                
                <!-- PESTAÑA AUDIO -->
                <Tab text="AUDIO">
                    <VBox spacing="25" alignment="TOP_CENTER" style="-fx-padding: 50 40 0 40;">
                        <!-- Fila Música -->
                        <HBox alignment="CENTER_LEFT" spacing="20">
                            <Label text="VOLUMEN MÚSICA" style="-fx-font-size: 24px; -fx-text-fill: #0d47a1; -fx-font-weight: bold;" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Slider fx:id="musicSlider" min="0" max="100" prefWidth="400" showTickLabels="false" showTickMarks="true" />
                        </HBox>
                        
                        <!-- Fila SFX -->
                        <HBox alignment="CENTER_LEFT" spacing="20">
                            <Label text="VOLUMEN EFECTOS (SFX)" style="-fx-font-size: 24px; -fx-text-fill: #0d47a1; -fx-font-weight: bold;" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Slider fx:id="sfxSlider" min="0" max="100" prefWidth="400" showTickLabels="false" showTickMarks="true" />
                        </HBox>
                    </VBox>
                </Tab>
            </tabs>
        </TabPane>
        
        <HBox spacing="40" alignment="CENTER" style="-fx-padding: 20 0 0 0;">
            <Button text="VOLVER AL MENÚ" onAction="#handleBack" styleClass="button-secondary" prefWidth="280" prefHeight="60" />
            <Button fx:id="applyButton" text="APLICAR CAMBIOS" onAction="#handleApply" styleClass="button-primary" prefWidth="350" prefHeight="70" />
        </HBox>
    </VBox>
</StackPane>
