<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane prefHeight="900.0" prefWidth="1600.0"
    stylesheets="@global_style.css"
    xmlns="http://javafx.com/javafx/25"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="vista.JuegoController"
    style="-fx-background-color: linear-gradient(to bottom, #1A2B3C, #2C4A6B);">

    <!-- ===== TABLERO (izquierda) ===== -->
    <center>
        <VBox alignment="TOP_CENTER" spacing="6" style="-fx-padding: 20;">

            <Label text="🐧 EL JUEGO DE PINGU 🐧"
                style="-fx-text-fill: #D6F9FF; -fx-font-size: 22px; -fx-font-weight: bold;" />

            <!-- El grid se genera desde el controlador -->
            <GridPane fx:id="grid_tablero" hgap="4" vgap="4"
                alignment="CENTER"
                style="-fx-padding: 10;" />

            <!-- Leyenda de colores -->
            <HBox alignment="CENTER" spacing="14" style="-fx-padding: 8 0 0 0;">
                <Label text="⬜ Normal" style="-fx-text-fill:white; -fx-font-size:11px;" />
                <Label text="🟫 Oso"    style="-fx-text-fill:white; -fx-font-size:11px;" />
                <Label text="🟦 Agujero" style="-fx-text-fill:white; -fx-font-size:11px;" />
                <Label text="🟩 Trineo"  style="-fx-text-fill:white; -fx-font-size:11px;" />
                <Label text="🟪 ?"       style="-fx-text-fill:white; -fx-font-size:11px;" />
                <Label text="🟥 Rompediza" style="-fx-text-fill:white; -fx-font-size:11px;" />
            </HBox>
        </VBox>
    </center>

    <!-- ===== PANEL LATERAL (derecha) ===== -->
    <right>
        <VBox prefWidth="360" spacing="14" styleClass="sidebar"
            style="-fx-padding: 24; -fx-background-color: rgba(26,43,60,0.92);">

            <!-- Turno actual -->
            <Label text="TURNO ACTUAL" style="-fx-text-fill: #87CEEB; -fx-font-size:13px; -fx-font-weight:bold;" />
            <Label fx:id="lbl_turno" text="---"
                style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight:bold;" />

            <Separator style="-fx-background-color: #4682B4;" />

            <!-- Estado del jugador -->
            <Label text="POSICIÓN"
                style="-fx-text-fill: #87CEEB; -fx-font-size:13px; -fx-font-weight:bold;" />
            <Label fx:id="lbl_posicion" text="---"
                style="-fx-text-fill: white; -fx-font-size: 18px;" />

            <Label text="INVENTARIO"
                style="-fx-text-fill: #87CEEB; -fx-font-size:13px; -fx-font-weight:bold;" />
            <Label fx:id="lbl_inventario" text="---"
                style="-fx-text-fill: white; -fx-font-size: 14px;" wrapText="true" />

            <Separator style="-fx-background-color: #4682B4;" />

            <!-- Selección de dado -->
            <Label text="DADO A USAR"
                style="-fx-text-fill: #87CEEB; -fx-font-size:13px; -fx-font-weight:bold;" />
            <ComboBox fx:id="combo_dado" prefWidth="280"
                style="-fx-background-color: #1A2B3C; -fx-text-fill: white;" />

            <!-- Botón principal -->
            <Button fx:id="btn_dado" text="🎲 TIRAR DADO"
                onAction="#handleTirarDado"
                prefWidth="280" prefHeight="60"
                styleClass="pixel-button"
                style="-fx-font-size:18px;" />

            <!-- Guardar partida -->
            <Button text="💾 GUARDAR"
                onAction="#handleGuardar"
                prefWidth="280" prefHeight="45"
                styleClass="pixel-button"
                style="-fx-font-size:14px;" />

            <!-- Volver al menú -->
            <Button text="🏠 MENÚ"
                onAction="#handleMenu"
                prefWidth="280" prefHeight="45"
                styleClass="pixel-button, button-red"
                style="-fx-font-size:14px;" />

            <Separator style="-fx-background-color: #4682B4;" />

            <!-- Log de eventos -->
            <Label text="LOG DE EVENTOS"
                style="-fx-text-fill: #87CEEB; -fx-font-size:13px; -fx-font-weight:bold;" />
            <TextArea fx:id="txt_log" editable="false" wrapText="true"
                prefWidth="280" prefHeight="250"
                style="-fx-control-inner-background: #0D1B2A; -fx-text-fill: #D6F9FF; -fx-font-size:12px;" />

        </VBox>
    </right>

</BorderPane>
