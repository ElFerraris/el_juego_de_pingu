<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="900.0" maxWidth="1800.0" minHeight="900.0" minWidth="1800.0" prefHeight="900.0" prefWidth="1800.0" stylesheets="@global_style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="vista.MenuPrincipal">
   <children>
      <!-- Fondo Degradado Glacial -->
      <AnchorPane prefHeight="900.0" prefWidth="1800.0" style="-fx-background-color: linear-gradient(to bottom, #1A2B3C, #4682B4);" />
      
      <Label layoutX="492.0" layoutY="150.0" prefHeight="133.0" prefWidth="816.0" styleClass="title-label" text="EL JUEGO DE PINGU" textAlignment="CENTER" />
      
      <Button fx:id="btn_nueva_partida" layoutX="779.0" layoutY="380.0" mnemonicParsing="false" onAction="#handleNuevaPartida" prefHeight="80.0" prefWidth="242.0" styleClass="pixel-button" text="NUEVA PARTIDA" />
      <Button fx:id="btn_cargar_partida" layoutX="779.0" layoutY="480.0" mnemonicParsing="false" onAction="#handleCargarPartida" prefHeight="80.0" prefWidth="242.0" styleClass="pixel-button" text="CARGAR PARTIDA" />
      <Button fx:id="btn_opciones" layoutX="779.0" layoutY="580.0" mnemonicParsing="false" prefHeight="80.0" prefWidth="242.0" styleClass="pixel-button" text="OPCIONES" />
      <Button fx:id="bnt_salir" layoutX="779.0" layoutY="750.0" mnemonicParsing="false" onAction="#handleSalir" prefHeight="80.0" prefWidth="242.0" styleClass="pixel-button, button-red" text="SALIR" />
      
      <Button fx:id="bnt_cerrar_sesion" layoutX="50.0" layoutY="40.0" mnemonicParsing="false" onAction="#handleCerrarSesion" prefHeight="60.0" prefWidth="200.0" styleClass="pixel-button" text="CERRAR SESION" />
   </children>
</AnchorPane>
