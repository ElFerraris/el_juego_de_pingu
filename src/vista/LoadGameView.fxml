<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controlador.MainMenuController" styleClass="root-plain-bg" prefHeight="720.0" prefWidth="1280.0">
    <stylesheets>
        <URL value="@style.css" />
    </stylesheets>
    
    <VBox spacing="40" alignment="CENTER" maxWidth="800" maxHeight="500" styleClass="glass-panel">
        <Label text="CARGAR PARTIDA" styleClass="title-text" />
        
        <Label text="Esta sección estará disponible en la Fase de Base de Datos." style="-fx-font-size: 24px; -fx-text-fill: #0d47a1;"/>
        
        <Button text="VOLVER AL MENÚ" onAction="#handleLogout" prefWidth="300" prefHeight="60" />
    </VBox>
</StackPane>
