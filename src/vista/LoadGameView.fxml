<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.effect.GaussianBlur?>

<StackPane xmlns:fx="http://javafx.com/fxml/1" fx:controller="controlador.LoadGameController" styleClass="root-plain-bg" prefHeight="720.0" prefWidth="1280.0">
    <Region style="-fx-background-color: rgba(5,20,60,0.2);"/>
    <VBox spacing="40" alignment="CENTER" maxWidth="700" maxHeight="650" styleClass="glass-panel">
        <Label text="MIS PARTIDAS" styleClass="title-text" />
        
        <VBox spacing="20" alignment="CENTER" VBox.vgrow="ALWAYS">
            <ListView fx:id="savedGamesListView" prefHeight="400" maxWidth="550" style="-fx-background-radius: 15; -fx-border-radius: 15;"/>
        </VBox>

        <HBox spacing="20" alignment="CENTER">
            <Button text="CARGAR PARTIDA" onAction="#handleConfirmLoadGame" prefWidth="250" styleClass="button-primary" />
            <Button text="VOLVER" onAction="#showMainMenu" prefWidth="200" />
        </HBox>
    </VBox>
</StackPane>
