<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.Group?>
<?import java.net.URL?>

<StackPane fx:id="rootStack" styleClass="root-plain-bg" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
           fx:controller="controlador.TableroController" prefHeight="720.0" prefWidth="1280.0">
    
    <stylesheets>
        <URL value="@style.css" />
    </stylesheets>

    <!-- CAPA 0: EL MUNDO (CÁMARA/TABLERO) -->
    <Pane fx:id="cameraViewport" mouseTransparent="false" pickOnBounds="true">
        <Group fx:id="zoomGroup">
            <!-- boardPane grande para permitir mucho margen de desplazamiento -->
            <Pane fx:id="boardPane" prefWidth="2400" prefHeight="2000" />
        </Group>
    </Pane>

    <!-- CAPA 1: LA INTERFAZ -->
    <BorderPane fx:id="gamePane" pickOnBounds="false">
        <!-- PANEL SUPERIOR: Información de Turno -->
        <top>
            <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-background-color: rgba(13,71,161,0.7); -fx-padding: 10;">
                <HBox fx:id="turnIndicatorBox" spacing="15" alignment="CENTER" />
                <Separator orientation="VERTICAL" />
                <Label fx:id="dadoResultadoLabel" text="Último dado: -" style="-fx-text-fill: #e3f2fd; -fx-font-size: 22px;" />
                
                <Region HBox.hgrow="ALWAYS" />
                
                <Button fx:id="btnMenu" onAction="#handleToggleMenu" styleClass="button-hamburger">
                    <graphic>
                        <VBox spacing="4" alignment="CENTER" fillWidth="false">
                            <Region styleClass="hamburger-line" />
                            <Region styleClass="hamburger-line" />
                            <Region styleClass="hamburger-line" />
                        </VBox>
                    </graphic>
                </Button>
            </HBox>
        </top>

        <!-- El centro debe dejarse libre y pickOnBounds="false" en el padre 
             permitirá que los clics lleguen al tablero de fondo. -->
        <center>
             <Region pickOnBounds="false" />
        </center>

        <!-- PANEL DERECHO ELIMINADO -->

        <bottom>
            <HBox spacing="30" alignment="CENTER" style="-fx-background-color: rgba(255,255,255,0.1); -fx-padding: 20;">
                <Region HBox.hgrow="ALWAYS" />
                
                <HBox spacing="20" alignment="CENTER">
                    <Button fx:id="btnDado" text="TIRAR DADO 🎲" onAction="#handleRollDice" prefWidth="200" prefHeight="60" styleClass="button-primary, button-dynamic" />
                    <Button fx:id="btnRecolectar" text="RECOLECTAR ❄" onAction="#handleCollectSnowballs" prefWidth="200" prefHeight="60" styleClass="button-secondary, button-dynamic" />
                    <Button fx:id="btnInventario" text="INVENTARIO 🎒" onAction="#handleOpenInventory" prefWidth="200" prefHeight="60" styleClass="button-secondary, button-dynamic" />
                </HBox>
                
                <Region HBox.hgrow="ALWAYS" />
                
                <Button onAction="#handleResetCamera" text="⌂" prefWidth="65" prefHeight="50" minWidth="65"
                        styleClass="button-secondary">
                    <tooltip><Tooltip text="Centrar Cámara" /></tooltip>
                </Button>
            </HBox>
        </bottom>
    </BorderPane>

    <!-- CAPA FLOTANTE: LOG LATERAL -->
    <HBox fx:id="logPanelContainer" alignment="CENTER_LEFT" pickOnBounds="false" maxWidth="-Infinity" StackPane.alignment="CENTER_LEFT">
        <VBox fx:id="logContentBox" prefWidth="320" styleClass="glass-panel" style="-fx-background-radius: 0 10 10 0; -fx-padding: 15;">
            <Label text="LOG DE PARTIDA" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #0d47a1;" />
            <Separator style="-fx-padding: 10 0;" />
            <TextArea fx:id="gameLogArea" editable="false" prefHeight="300" VBox.vgrow="ALWAYS"
                      style="-fx-control-inner-background: rgba(255,255,255,0.7); -fx-text-fill: #0d47a1; -fx-font-size: 14px; -fx-background-radius: 5;" 
                      wrapText="true" />
            
            <Label text="PINGÜINOS" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #0d47a1; -fx-padding: 10 0 5 0;" />
            <VBox fx:id="secondaryStatusContainer" spacing="5" style="-fx-background-color: rgba(255,255,255,0.3); -fx-padding: 10; -fx-background-radius: 5;" />
        </VBox>
        <Button fx:id="btnToggleLog" text="▶" onAction="#handleToggleLog" styleClass="button-secondary" 
                style="-fx-background-radius: 0 10 10 0; -fx-font-size: 22px; -fx-padding: 20 10; -fx-min-width: 40px;"/>
    </HBox>

    <!-- CAPA: INVENTARIO DESLIZANTE (FLOTANTE) -->
    <VBox fx:id="inventoryOverlayPanel" visible="false" alignment="BOTTOM_CENTER" pickOnBounds="false">
        <VBox spacing="15" maxWidth="700" styleClass="inventory-floating-panel">
            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 0 0 10 0;">
                <Label text="MOCHILA" style="-fx-font-size: 24px; -fx-font-weight: bold;" />
                <Region HBox.hgrow="ALWAYS" />
                <Button text="✕" onAction="#handleCloseInventory" styleClass="button-back-small" />
            </HBox>
            <Separator />
            <FlowPane fx:id="inventoryFlowPane" hgap="15" vgap="15" alignment="CENTER" prefHeight="150" />
        </VBox>
        <padding>
            <Insets bottom="100" />
        </padding>
    </VBox>


    <!-- CAPA 3: OVERLAY CONTENEDOR (Fondo Oscurecido) -->
    <StackPane fx:id="overlayPane" visible="false" styleClass="overlay-pane">
        
        <!-- PANEL DE PAUSA (HAMBURGUESA) -->
        <VBox fx:id="menuPausa" visible="false" spacing="20" alignment="CENTER" maxWidth="400" maxHeight="500" styleClass="glass-panel, floating-window">
            <Label text="MENÚ" styleClass="title-text" style="-fx-font-size: 50px;" />
            <Separator />
            <Button text="REANUDAR" onAction="#handleResume" prefWidth="300" prefHeight="60" styleClass="button-primary" />
            <Button text="OPCIONES" onAction="#handleShowOptions" prefWidth="300" prefHeight="60" styleClass="button-secondary" />
            <Button text="MENÚ PRINCIPAL" onAction="#handleGoToMainMenu" prefWidth="300" prefHeight="60" styleClass="button-secondary" />
            <Button text="SALIR AL ESCRITORIO" onAction="#handleExitGame" prefWidth="300" prefHeight="60" styleClass="button-danger" />
        </VBox>

        <!-- PANEL DE OPCIONES INTEGRADO -->
        <VBox fx:id="optionsOverlay" visible="false" spacing="20" alignment="CENTER" maxWidth="900" maxHeight="650" styleClass="glass-panel, floating-window">
            <Label text="OPCIONES" styleClass="title-text" style="-fx-font-size: 50px;" />
            
            <TabPane tabClosingPolicy="UNAVAILABLE" prefHeight="350">
                <tabs>
                    <Tab text="VÍDEO">
                        <VBox spacing="20" style="-fx-padding: 30;">
                            <HBox alignment="CENTER_LEFT">
                                <Label text="RESOLUCIÓN" style="-fx-font-size: 20px; -fx-text-fill: #0d47a1;" />
                                <Region HBox.hgrow="ALWAYS" />
                                <ComboBox fx:id="resComboOverlay" prefWidth="300" />
                            </HBox>
                            <HBox alignment="CENTER_LEFT">
                                <Label text="PANTALLA COMPLETA" style="-fx-font-size: 20px; -fx-text-fill: #0d47a1;" />
                                <Region HBox.hgrow="ALWAYS" />
                                <CheckBox fx:id="fsCheckOverlay" styleClass="premium-checkbox" />
                            </HBox>
                        </VBox>
                    </Tab>
                    <Tab text="AUDIO">
                        <VBox spacing="20" style="-fx-padding: 30;">
                            <HBox alignment="CENTER_LEFT">
                                <Label text="MÚSICA" style="-fx-font-size: 20px; -fx-text-fill: #0d47a1;" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Slider fx:id="musicSliderOverlay" prefWidth="350" min="0" max="100" />
                            </HBox>
                            <HBox alignment="CENTER_LEFT">
                                <Label text="EFECTOS (SFX)" style="-fx-font-size: 20px; -fx-text-fill: #0d47a1;" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Slider fx:id="sfxSliderOverlay" prefWidth="350" min="0" max="100" />
                            </HBox>
                        </VBox>
                    </Tab>
                </tabs>
            </TabPane>
            
            <HBox spacing="20" alignment="CENTER">
                <Button text="VOLVER" onAction="#handleBackFromOptions" prefWidth="250" styleClass="button-secondary" />
                <Button fx:id="btnApplyOverlay" text="APLICAR CAMBIOS" onAction="#handleApplyOptionsOverlay" prefWidth="350" styleClass="button-primary" />
            </HBox>
        </VBox>

        <!-- PANEL DE CONFIRMACIÓN -->
        <VBox fx:id="confirmOverlay" visible="false" spacing="30" alignment="CENTER" maxWidth="600" maxHeight="350" styleClass="glass-panel, floating-window">
            <Label fx:id="confirmTitle" text="¿ESTÁS SEGURO?" styleClass="title-text" style="-fx-font-size: 40px;" />
            <Label fx:id="confirmMessage" text="La partida se guardará automáticamente." 
                   style="-fx-font-size: 22px; -fx-text-fill: #0d47a1; -fx-text-alignment: center;" wrapText="true" />
            <HBox spacing="30" alignment="CENTER">
                <Button text="SÍ, SALIR" onAction="#handleConfirmYes" prefWidth="220" prefHeight="50" styleClass="button-danger" />
                <Button text="NO, VOLVER" onAction="#handleConfirmNo" prefWidth="220" prefHeight="50" styleClass="button-secondary" />
            </HBox>
        </VBox>

        <!-- PANEL DE CONFIRMACIÓN DE OBJETOS -->
        <VBox fx:id="itemConfirmOverlay" visible="false" spacing="30" alignment="CENTER" maxWidth="600" maxHeight="400" styleClass="glass-panel, floating-window">
            <Label fx:id="itemConfirmTitle" text="USAR OBJETO" styleClass="title-text" style="-fx-font-size: 40px;" />
            <VBox alignment="CENTER" spacing="10">
                <Label fx:id="itemConfirmMessage" text="¿Quieres usar este objeto?" 
                       style="-fx-font-size: 22px; -fx-text-fill: #0d47a1; -fx-text-alignment: center;" wrapText="true" />
                <Label fx:id="itemConfirmSubMessage" text="Este objeto tiene un uso automático." 
                       style="-fx-font-size: 16px; -fx-text-fill: #546e7a; -fx-text-alignment: center;" visible="false" />
            </VBox>
            <HBox spacing="30" alignment="CENTER">
                <Button fx:id="btnItemConfirmYes" text="SÍ, USAR" onAction="#handleItemConfirmYes" prefWidth="220" prefHeight="50" styleClass="button-primary" />
                <Button text="NO, VOLVER" onAction="#handleItemConfirmNo" prefWidth="220" prefHeight="50" styleClass="button-secondary" />
            </HBox>
        </VBox>
    </StackPane>

    <!-- CAPA 4: EVENTOS (OCURRENCIAS EN EL MUNDO) - CAPA SUPERIOR ABSOLUTA -->
    <StackPane fx:id="eventOverlay" visible="false">
        <!-- Fondo oscurecido -->
        <Pane fx:id="eventDimmer" style="-fx-background-color: rgba(0,0,0,0.6);" />
        
        <!-- Capa para resaltar fichas (Transparente) -->
        <Pane fx:id="highlightLayer" pickOnBounds="false" />
        
        <!-- Caja de Diálogo (Bottom) -->
        <VBox alignment="BOTTOM_CENTER" pickOnBounds="false">
            <padding><Insets bottom="50"/></padding>
            <VBox fx:id="eventDialogueBox" alignment="CENTER" spacing="15" maxWidth="700" 
                  styleClass="glass-panel, floating-window" style="-fx-padding: 30; -fx-border-width: 3;">
                <Label fx:id="eventTitleLabel" text="EVENTO" styleClass="title-text" style="-fx-font-size: 34px;" />
                <Label fx:id="eventMessageLabel" text="Descripción del evento..." 
                       style="-fx-font-size: 22px; -fx-text-fill: #0d47a1; -fx-text-alignment: center;" wrapText="true" />
                <Button onAction="#handleCloseEvent" text="CONTINUAR ▶" prefWidth="220" prefHeight="50" styleClass="button-primary" />
            </VBox>
        </VBox>
    </StackPane>

    <!-- CAPA 5: NOTIFICACIONES VOLÁTILES (TOP CENTER) - CAPA MÁS ALTA -->
    <StackPane fx:id="eventNotificationContainer" pickOnBounds="false" mouseTransparent="true" 
               StackPane.alignment="TOP_CENTER" translateY="80">
        <Label fx:id="eventNotificationLabel" text="¡EVENTO!" visible="false" 
               styleClass="event-notification-text" />
    </StackPane>
</StackPane>
