<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.StackPane?>

<StackPane id="loginPane" stylesheets="@login.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="vista.Login">
   <children>
      <AnchorPane maxHeight="900.0" maxWidth="1800.0" minHeight="900.0" minWidth="1800.0" prefHeight="900.0" prefWidth="1800.0">
         <children>
            <Button fx:id="btn_login" layoutX="152.0" layoutY="527.0" mnemonicParsing="false" onAction="#handleLogin" prefHeight="51.0" prefWidth="188.0" text="LOGIN" />
            <Hyperlink fx:id="link_regis" layoutX="152.0" layoutY="585.0" onAction="#alternarModo" prefHeight="23.0" prefWidth="188.0" style="-fx-alignment: center;" text="¿No tienes cuenta? Regístrate" />
            <PasswordField fx:id="text_pswd" layoutX="152.0" layoutY="450.0" prefHeight="25.0" prefWidth="188.0" />
            <TextField fx:id="text_user" layoutX="152.0" layoutY="373.0" prefHeight="25.0" prefWidth="188.0" />
      
            <Label layoutX="152.0" layoutY="356.0" prefHeight="17.0" prefWidth="188.0" text="Usuario" />
            <Label layoutX="152.0" layoutY="433.0" prefHeight="17.0" prefWidth="188.0" text="Contraseña" />
            <Label fx:id="text_error" layoutX="152.0" layoutY="264.0" prefHeight="51.0" prefWidth="188.0" styleClass="error-label" text=" " />
         </children>
      </AnchorPane>
   </children>
</StackPane>
