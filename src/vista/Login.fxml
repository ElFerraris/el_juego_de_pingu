<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.StackPane?>

<StackPane id="loginPane" maxHeight="700.0" maxWidth="1200.0" minHeight="700.0" minWidth="1200.0" prefHeight="700.0" prefWidth="1200.0" stylesheets="@login.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="vista.Login">
   <children>
      <AnchorPane maxHeight="700.0" maxWidth="1200.0" minHeight="700.0" minWidth="1200.0" prefHeight="700.0" prefWidth="1200.0">
         <children>
            <Button fx:id="btn_login" layoutX="99.0" layoutY="438.0" mnemonicParsing="false" onAction="#handleLogin" prefHeight="51.0" prefWidth="188.0" text="LOGIN" />
            <Hyperlink fx:id="link_regis" layoutX="99.0" layoutY="496.0" onAction="#alternarModo" prefHeight="23.0" prefWidth="188.0" style="-fx-alignment: center;" text="¿No tienes cuenta? Regístrate" />
            <PasswordField fx:id="text_pswd" layoutX="99.0" layoutY="361.0" prefHeight="25.0" prefWidth="188.0" />
            <TextField fx:id="text_user" layoutX="99.0" layoutY="284.0" prefHeight="25.0" prefWidth="188.0" />
      
            <Label layoutX="99.0" layoutY="267.0" prefHeight="17.0" prefWidth="188.0" text="Usuario" />
            <Label layoutX="99.0" layoutY="344.0" prefHeight="17.0" prefWidth="188.0" text="Contraseña" />
            <Label fx:id="text_error" layoutX="99.0" layoutY="175.0" prefHeight="51.0" prefWidth="188.0" styleClass="error-label" text=" " />
         </children>
      </AnchorPane>
   </children>
</StackPane>
